{
  "build": {
    "env": {
      "CI": "false"
    }
  },
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "facemocap.vercel.app"
        }
      ],
      "destination": "https://www.miniface.org/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "facemocap.radframes.app"
        }
      ],
      "destination": "https://www.miniface.org/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "facemocap.radframes.com"
        }
      ],
      "destination": "https://www.miniface.org/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "miniface.org"
        }
      ],
      "destination": "https://www.miniface.org/$1",
      "permanent": true
    }
  ]
}
